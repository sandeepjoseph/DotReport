@inherits LayoutComponentBase
@inject ThemeService Theme
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="ec-shell @Theme.CurrentThemeClass" id="ec-root">

    <header class="ec-topbar">
        <div class="ec-topbar__brand">
            <a href="/" class="ec-xyopst-brand" title="XyOPST Edge">
                <svg class="ec-xyopst-mark" viewBox="0 0 44 48" xmlns="http://www.w3.org/2000/svg" fill="none">
                    <circle cx="22" cy="8" r="6" fill="#f59e0b"/>
                    <line x1="22" y1="14" x2="22" y2="29" stroke="#f59e0b" stroke-width="3.5" stroke-linecap="round"/>
                    <line x1="22" y1="20" x2="5"  y2="10" stroke="#f59e0b" stroke-width="3.5" stroke-linecap="round"/>
                    <line x1="22" y1="20" x2="39" y2="10" stroke="#f59e0b" stroke-width="3.5" stroke-linecap="round"/>
                    <line x1="22" y1="29" x2="10" y2="45" stroke="#f59e0b" stroke-width="3.5" stroke-linecap="round"/>
                    <line x1="22" y1="29" x2="34" y2="45" stroke="#f59e0b" stroke-width="3.5" stroke-linecap="round"/>
                </svg>
                <span class="ec-xyopst-wordmark">X<span class="ec-xyopst-rest">YOPST</span></span>
            </a>
            <div class="ec-topbar__divider"></div>
            <div class="ec-topbar__product">
                <span class="ec-topbar__product-name">DotReport</span>
                <span class="ec-topbar__product-sub">EdgeCore</span>
            </div>
        </div>

        <nav class="ec-topbar__nav">
            <a href="/" class="ec-nav-link @(Nav.Uri.EndsWith("/") || Nav.Uri.EndsWith("/#") ? "ec-nav-link--active" : "")">Home</a>
            <a href="/provision" class="ec-nav-link @(Nav.Uri.Contains("provision") ? "ec-nav-link--active" : "")">Provision</a>
            <a href="/report"    class="ec-nav-link @(Nav.Uri.Contains("/report")   ? "ec-nav-link--active" : "")">Report</a>
            <a href="/chat"      class="ec-nav-link @(Nav.Uri.Contains("/chat")     ? "ec-nav-link--active" : "")">Intelligence</a>
        </nav>

        <div class="ec-topbar__controls">
            <ModelStatusBar />
            <ThemeToggle />
        </div>
    </header>

    <main class="ec-main">
        @Body
    </main>

    <footer class="ec-footer">
        <div class="ec-footer__left">
            <svg class="ec-footer__logo-mark" viewBox="0 0 28 32" xmlns="http://www.w3.org/2000/svg" fill="none">
                <circle cx="14" cy="5" r="4" fill="#f59e0b"/>
                <line x1="14" y1="9"  x2="14" y2="19" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round"/>
                <line x1="14" y1="13" x2="3"  y2="7"  stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round"/>
                <line x1="14" y1="13" x2="25" y2="7"  stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round"/>
                <line x1="14" y1="19" x2="6"  y2="29" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round"/>
                <line x1="14" y1="19" x2="22" y2="29" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
            <div class="ec-footer__company">
                <span class="ec-footer__company-name">XyOPST Intelligence</span>
                <span class="ec-footer__company-tag">Where social meets impact!</span>
            </div>
        </div>
        <div class="ec-footer__center">DotReport EdgeCore · Community Edition · MIT License</div>
        <div class="ec-footer__right">
            <span>hello@xyopst.com</span>
            <span>&copy; 2026 XyOPST</span>
        </div>
    </footer>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            await JS.InvokeVoidAsync("dismissBootScreen");
        }
        catch
        {
            // Safe to ignore — boot screen may already be gone.
        }
    }
}
