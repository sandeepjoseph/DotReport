@page "/"
@inject NavigationManager Nav
@inject ConsolidatorProxy Proxy
@inject ThemeService Theme
@inject VRAMDetector VramDetector

<PageTitle>DotReport EdgeCore</PageTitle>

<div class="ec-index">

    <!-- Hero -->
    <section class="ec-hero">
        <p class="ec-hero__eyebrow">XyOPST Intelligence · DotReport EdgeCore</p>
        <h1 class="ec-hero__title">Sovereign Document<br/><span>Intelligence Engine</span></h1>
        <p class="ec-hero__description">
            Upload any document — PDF, spreadsheet, Word, or CSV — and ask questions in plain English.
            Multi-tier intelligence: built-in engine works immediately, optional local AI models for deeper analysis.
            Zero server compute. Zero data transmission. Your documents never leave your machine.
        </p>
        <div class="ec-hero__actions">
            <button class="ec-btn ec-btn--primary" @onclick="GoChat">
                Open Intelligence Chat
            </button>
            <button class="ec-btn ec-btn--ghost" @onclick="GoReport">
                Single Document Report
            </button>
        </div>
        <span class="ec-hero__note">No setup required · built-in engine ready · upload and ask anything</span>
    </section>

    <!-- Features -->
    <section class="ec-features">
        <div class="ec-feature">
            <div class="ec-feature__title">Upload &amp; Ask</div>
            <p class="ec-feature__body">Drop PDFs, spreadsheets, Word docs, or CSV files into the Intelligence Chat. Ask anything — the built-in engine extracts fields, dates, and amounts immediately, no setup.</p>
        </div>
        <div class="ec-feature">
            <div class="ec-feature__title">Cross-Document Analysis</div>
            <p class="ec-feature__body">Upload multiple documents and compare them automatically. Matching amounts, date correlations, and discrepancies surface across your entire document set.</p>
        </div>
        <div class="ec-feature">
            <div class="ec-feature__title">Edge Sovereignty</div>
            <p class="ec-feature__body">All processing runs in your browser via Blazor WebAssembly. Zero telemetry. Zero API calls. Your documents never leave your machine.</p>
        </div>
    </section>

    <!-- Device Assessment -->
    <section class="ec-device-panel">
        <div class="ec-device-panel__title">Device Assessment</div>
        @if (_caps is not null)
        {
            <div class="ec-device-grid">
                <div class="ec-device-item @(_caps.WebGpuSupported ? "ec-device-item--ok" : "ec-device-item--warn")">
                    <span class="ec-device-item__key">WebGPU</span>
                    <span class="ec-device-item__val">@(_caps.WebGpuSupported ? "Available" : "Unavailable")</span>
                </div>
                <div class="ec-device-item ec-device-item--ok">
                    <span class="ec-device-item__key">WASM</span>
                    <span class="ec-device-item__val">@(_caps.WebAssemblySupported ? "Available" : "Unavailable")</span>
                </div>
                <div class="ec-device-item @(_caps.HasSufficientVram ? "ec-device-item--ok" : "ec-device-item--warn")">
                    <span class="ec-device-item__key">VRAM</span>
                    <span class="ec-device-item__val">@(_caps.EstimatedVramMb) MB</span>
                </div>
                <div class="ec-device-item">
                    <span class="ec-device-item__key">Build</span>
                    <span class="ec-device-item__val">@_caps.RecommendedBuild.ToString()</span>
                </div>
                <div class="ec-device-item ec-device-item--wide">
                    <span class="ec-device-item__key">Adapter</span>
                    <span class="ec-device-item__val">@_caps.AdapterName</span>
                </div>
            </div>
        }
        else
        {
            <div class="ec-scanning">
                <span class="ec-scanning__dot"></span>
                <span class="ec-scanning__dot"></span>
                <span class="ec-scanning__dot"></span>
                <span class="ec-scanning__label">Scanning device</span>
            </div>
        }
    </section>

    <!-- Spec Table -->
    <section class="ec-spec-table">
        <div class="ec-spec-row ec-spec-row--header">
            <span>Component</span><span>Specification</span><span>Status</span>
        </div>
        <div class="ec-spec-row"><span>Tier 1 — Cloud LLM</span><span>Server proxy · Azure OpenAI / Anthropic · highest quality</span><span>Optional</span></div>
        <div class="ec-spec-row"><span>Tier 2 — Local ONNX</span><span>Phi-4 Mini · Qwen 2.5 · WebGPU accelerated · ~3–5 GB</span><span>Optional</span></div>
        <div class="ec-spec-row"><span>Tier 3 — Built-in Engine</span><span>Pattern extraction · field detection · always available</span><span>Ready ✓</span></div>
        <div class="ec-spec-row"><span>Circuit Breaker</span><span>Auto-fallback across tiers · decorrelated jitter backoff</span><span>Active</span></div>
        <div class="ec-spec-row"><span>Document Formats</span><span>PDF · DOCX · XLSX · CSV · TXT · MD</span><span>Ready ✓</span></div>
        <div class="ec-spec-row"><span>Cross-Doc Intelligence</span><span>Amount matching · discrepancy detection · date clustering</span><span>Ready ✓</span></div>
        <div class="ec-spec-row"><span>Report Export</span><span>PDF generation · in-process · no server</span><span>Ready ✓</span></div>
        <div class="ec-spec-row"><span>Data Sovereignty</span><span>Zero telemetry · zero API calls · 100% client-side</span><span>Enforced</span></div>
    </section>

</div>

@code {
    private DeviceCapabilities? _caps;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            _caps = await VramDetector.DetectAsync();
        }
        catch
        {
            // VRAM detection is best-effort.
        }
        StateHasChanged();
    }

    private void GoChat()      => Nav.NavigateTo("/chat");
    private void GoReport()    => Nav.NavigateTo("/report");
}
