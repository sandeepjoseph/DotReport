@using Microsoft.AspNetCore.Components.Forms

<div class="ec-uploader">
    <label class="ec-uploader__zone @(_dragging ? "ec-uploader__zone--drag" : "")"
           @ondragover="e => _dragging = true"
           @ondragleave="e => _dragging = false"
           @ondrop="HandleDrop">
        <span class="ec-uploader__icon">▣</span>
        <span class="ec-uploader__label">DROP DOCUMENT HERE</span>
        <span class="ec-uploader__sub">TXT / PDF / MD / CSV / DOCX / XLSX</span>
        <InputFile OnChange="HandleFileSelected" accept=".txt,.md,.csv,.tsv,.pdf,.docx,.xlsx" style="display:none" />
    </label>

    @if (_parsing)
    {
        <div class="ec-uploader__loaded">
            <span class="ec-label">PARSING...</span>
            <span class="ec-uploader__filename">@_loadedFileName</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(_parseError))
    {
        <div class="ec-uploader__loaded ec-uploader__loaded--error">
            <span class="ec-label">ERROR</span>
            <span class="ec-uploader__filename">@_parseError</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(_loadedFileName))
    {
        <div class="ec-uploader__loaded">
            <span class="ec-label">LOADED</span>
            <span class="ec-uploader__filename">@_loadedFileName</span>
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<ReportDocument> OnDocumentLoaded { get; set; }
    [Inject] DocumentParserFactory ParserFactory { get; set; } = default!;

    private bool _dragging;
    private bool _parsing;
    private string _loadedFileName = string.Empty;
    private string? _parseError;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file is null) return;
        await ReadAndNotify(file);
    }

    private async Task HandleDrop(DragEventArgs e)
    {
        _dragging = false;
        // DragEvent file access requires JS interop in WASM — wired up in app-interop.js
    }

    private async Task ReadAndNotify(IBrowserFile file)
    {
        _loadedFileName = file.Name;
        _parsing = true;
        _parseError = null;
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
            var content = await ParserFactory.ExtractTextAsync(stream, file.Name);

            var doc = new ReportDocument
            {
                DocumentId     = Guid.NewGuid().ToString("N"),
                SourceFileName = file.Name,
                SourceContent  = content
            };

            await OnDocumentLoaded.InvokeAsync(doc);
        }
        catch (Exception ex)
        {
            _parseError = ex.Message;
            _loadedFileName = string.Empty;
        }
        finally
        {
            _parsing = false;
            StateHasChanged();
        }
    }
}
