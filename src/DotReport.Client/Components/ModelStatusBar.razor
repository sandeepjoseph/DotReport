@inject ConsolidatorProxy Proxy
@inject InferenceCircuitBreaker Breaker
@implements IDisposable

<div class="ec-agent-bar">
    @foreach (var agent in Breaker.GetAgentInfos())
    {
        <div class="ec-agent @(agent.IsReady ? "ec-agent--ready" : "ec-agent--idle")
                             @(agent.IsActive ? "ec-agent--active" : "")"
             title="@agent.AgentLabel — @agent.BackendName">
            <span class="ec-agent__led"></span>
            <span class="ec-agent__label">@agent.AgentLabel</span>
        </div>
    }
    @if (Proxy.State.IsProcessing)
    {
        <div class="ec-agent ec-agent--live" title="Inference running">
            <span class="ec-agent__led ec-agent__led--pulse"></span>
            <span class="ec-agent__label">LIVE</span>
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
        => Proxy.OnStateChanged += StateHasChanged;

    public void Dispose() => Proxy.OnStateChanged -= StateHasChanged;
}
