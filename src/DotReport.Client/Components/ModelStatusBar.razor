@inject ConsolidatorProxy Proxy
@implements IDisposable

<div class="ec-model-statusbar">
    <div class="ec-model-indicator @GetClass(Proxy.State.PrimaryStatus)" title="Phi-4 Mini (Primary)">
        <span class="ec-model-indicator__led"></span>
        <span class="ec-model-indicator__label">P</span>
    </div>
    <div class="ec-model-indicator @GetClass(Proxy.State.BackupStatus)" title="Qwen 2.5 (Backup)">
        <span class="ec-model-indicator__led"></span>
        <span class="ec-model-indicator__label">B</span>
    </div>
    @if (Proxy.State.IsProcessing)
    {
        <div class="ec-model-indicator ec-model-indicator--active">
            <span class="ec-model-indicator__led ec-model-indicator__led--pulse"></span>
            <span class="ec-model-indicator__label">INF</span>
        </div>
    }
</div>

@code {
    protected override void OnInitialized()
        => Proxy.OnStateChanged += StateHasChanged;

    private static string GetClass(ModelStatus s) => s switch
    {
        ModelStatus.Ready       => "ec-model-indicator--ready",
        ModelStatus.Loading     => "ec-model-indicator--loading",
        ModelStatus.Downloading => "ec-model-indicator--loading",
        ModelStatus.Error       => "ec-model-indicator--error",
        _                       => "ec-model-indicator--idle"
    };

    public void Dispose() => Proxy.OnStateChanged -= StateHasChanged;
}
