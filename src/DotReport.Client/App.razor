<ErrorBoundary>
    <ChildContent>
        <Router AppAssembly="@typeof(App).Assembly">
            <Found Context="routeData">
                <RouteView RouteData="@routeData" DefaultLayout="@typeof(DotReport.Client.Layout.MainLayout)" />
                <FocusOnNavigate RouteData="@routeData" Selector="h1" />
            </Found>
            <NotFound>
                <PageTitle>Not Found — DotReport EdgeCore</PageTitle>
                <LayoutView Layout="@typeof(DotReport.Client.Layout.MainLayout)">
                    <div class="ec-not-found">
                        <span class="ec-label">404</span>
                        <p>Node not mapped.</p>
                    </div>
                </LayoutView>
            </NotFound>
        </Router>
    </ChildContent>
    <ErrorContent Context="ex">
        <div style="position:fixed;inset:0;background:#060609;display:flex;flex-direction:column;align-items:center;justify-content:center;font-family:monospace;color:#f43f5e;gap:12px;padding:24px;">
            <div style="font-size:11px;letter-spacing:0.2em;font-weight:bold;">ENGINE RENDER FAILURE</div>
            <div style="font-size:9px;letter-spacing:0.12em;color:#f0f0f8;max-width:480px;text-align:center;word-break:break-all;">@ex?.Message</div>
            <button onclick="location.reload()" style="margin-top:8px;padding:8px 24px;background:transparent;border:1px solid #f43f5e;color:#f43f5e;font-family:monospace;font-size:11px;letter-spacing:0.12em;cursor:pointer;">RELOAD</button>
        </div>
    </ErrorContent>
</ErrorBoundary>
